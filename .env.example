# Path to the tipitaka-translation-data.db SQLite file (from dpd-db).
# Used by scan_book / scan_book_pretty / summarize_tsv.
VUTTA_CANON_DB=~/path/to/dpd-db/resources/tipitaka_translation_db/tipitaka-translation-data.db

# Path to the CST romn/ directory of TEI/XML files (from dpd-db submodule).
# Used by scan_cst_xml.
VUTTA_CST_DIR=~/path/to/dpd-db/resources/dpd_submodules/cst/romn
